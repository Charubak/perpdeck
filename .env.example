# EVM RPCs
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Solana RPC
HELIUS_API_KEY=your_helius_api_key_here

# Redis (Upstash on Railway)
REDIS_URL=redis://localhost:6379

# Database (Railway Postgres)
DATABASE_URL=postgresql://localhost:5432/perpdeck

# Sentry
SENTRY_DSN=

# Axiom
AXIOM_TOKEN=
AXIOM_DATASET=perpdeck

# API
PORT=3001
NODE_ENV=development

# Lighter API key (required to read Lighter positions — get from lighter.xyz settings)
# Without this, Lighter adapter returns empty positions.
LIGHTER_API_KEY=

# Extended API key (required to read Extended positions — get from extended.exchange API Management)
# Extended positions are tied to a sub-account + API key, not derivable from address alone.
EXTENDED_API_KEY=

# Local dev: swap to mock adapters (no live API calls)
# USE_MOCK_ADAPTERS=true
